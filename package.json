{
  "name": "antigravity-agent-manager-zh-cn",
  "displayName": "Agent Manager ZH-CN Patch",
  "description": "Chinese Localization Patch for Antigravity Agent Manager",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "publisher": "Uncle-Gao",
  "author": {
    "name": "Uncle-Gao",
    "url": "https://github.com/Uncle-Gao"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Uncle-Gao/antigravity-agent-manager-zh-cn.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-agent-manager-zh-cn.applyPatch",
        "title": "汉化 Agent Manager (Apply ZH-CN Patch)"
      },
      {
        "command": "antigravity-agent-manager-zh-cn.revertPatch",
        "title": "还原 Agent Manager (Revert ZH-CN Patch)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}